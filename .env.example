# Pick ONE of the three authentication paths.
# Generate credentials at https://groww.in/trade-api/api-keys

# --- Path A: short-lived access token (paste from the dashboard) ---
# GROWW_ACCESS_TOKEN=

# --- Path B: API key + secret (rotated daily by Groww) ---
# GROWW_API_KEY=
# GROWW_API_SECRET=

# --- Path C: long-lived TOTP token (recommended) ---
# GROWW_API_KEY=
# GROWW_TOTP_SECRET=

# Optional knobs
NIFTY_REFRESH_SECONDS=3
NIFTY_INSTRUMENTS_CACHE_HOURS=12
